{
  "name": "brc-analytics",
  "version": "0.28.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "sites/*"
  ],
  "scripts": {
    "dev": "./scripts/dev-site.sh brc-analytics",
    "build:local": "./scripts/build-site.sh brc-analytics local",
    "build:dev": "./scripts/build-site.sh brc-analytics dev",
    "build:prod": "./scripts/build-site.sh brc-analytics prod",
    "dev:ga2": "./scripts/dev-site.sh ga2",
    "build-local:ga2": "./scripts/build-site.sh ga2 local",
    "build-dev:ga2": "./scripts/build-site.sh ga2 dev",
    "build-prod:ga2": "./scripts/build-site.sh ga2 prod",
    "start:brc": "npx serve sites/brc-analytics/out",
    "start:ga2": "npx serve sites/ga2/out",
    "lint": "eslint .",
    "check-format": "prettier --check .",
    "format": "prettier --write . --cache",
    "format:python": "./scripts/format-python.sh",
    "lint:python": "./scripts/lint-python.sh",
    "prepare": "husky",
    "test": "jest --runInBand --passWithNoTests",
    "test:e2e": "npx playwright test",
    "test:e2e:api": "npx playwright test --config=playwright.api.config.ts",
    "test:e2e:ga2": "npx playwright test --config=playwright.ga2.config.ts",
    "select-ga2-organism-images": "python3 -m catalog.ga2.build.py.select_images_for_organism",
    "build-brc-db": "NODE_ENV=production esrun catalog/build/ts/build-catalog.ts",
    "build-ga2-db": "esrun catalog/ga2/build/ts/build-catalog.ts",
    "build-brc-from-ncbi": "python3 -m catalog.build.py.build_files_from_ncbi",
    "build-ga2-from-ncbi": "python3 -m catalog.ga2.build.py.build_files_from_ncbi",
    "fetch-ga2-organism-images": "python3 catalog/ga2/build/py/fetch_images_from_bucket.py",
    "update-ga2-assemblies": "python3 -m catalog.ga2.build.py.update_assemblies",
    "iwc-manifest-to-workflows-yaml": "python3 -m catalog.py_package.catalog_build.iwc_manifest_to_workflows_yaml ./catalog/source/workflows.yml --exclude-other",
    "lint-schema": "linkml-lint ./catalog/py_package/catalog_build/schema --validate --verbose",
    "gen-schema": "./catalog/schema/scripts/gen-schema.sh",
    "test-gen-python": "./catalog/schema/scripts/test-gen-python.sh",
    "validate-brc-catalog": "./catalog/schema/scripts/validate-catalog.sh",
    "validate-ga2-catalog": "./catalog/ga2/schema/scripts/validate-catalog.sh"
  },
  "dependencies": {
    "@databiosphere/findable-ui": "^55.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11",
    "@emotion/styled": "^11.14.1",
    "@mdx-js/loader": "^3.0.1",
    "@mdx-js/react": "^3.0.1",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@mui/material-nextjs": "^9",
    "@next/mdx": "^16",
    "@observablehq/plot": "^0.6.17",
    "@sentry/nextjs": "^10.27.0",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.13",
    "copy-to-clipboard": "^3.3.3",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "ky": "^1.7.2",
    "next": "^16",
    "next-compose-plugins": "^2.2.1",
    "next-mdx-remote": "^6",
    "papaparse": "^5.5.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-dropzone": "^14.3.8",
    "react-gtm-module": "^2",
    "react-idle-timer": "^5.7.2",
    "react-window": "^1.8.11",
    "rehype-raw": "^7.0.0",
    "rehype-react": "^8.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "slugify": "^1.6.6",
    "unified": "^11.0.5",
    "uuid": "^13.0.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@actions/core": "^1.11.1",
    "@babel/core": "^7.17.10",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@commitlint/format": "^19.8.0",
    "@commitlint/lint": "^19.8.0",
    "@commitlint/load": "^19.8.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9",
    "@next/eslint-plugin-next": "^16",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^16.3.1",
    "@types/d3": "^7.4.3",
    "@types/mdx": "^2.0.11",
    "@types/node": "22.13.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-gtm-module": "^2.0.1",
    "@types/react-window": "^1.8.5",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "babel-loader": "^9.2.1",
    "csv-parse": "^5.6.0",
    "eslint": "^9",
    "eslint-config-next": "^16",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63",
    "eslint-plugin-perfectionist": "^4",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7",
    "eslint-plugin-sonarjs": "^3.0.7",
    "eslint-plugin-sort-destructure-keys": "^3",
    "esrun": "^3.2.26",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^5.9.3",
    "yaml": "^2.7.0"
  },
  "engines": {
    "node": "22.13.0"
  }
}
